# ─────────────────────────────────────────────
# WhatsApp AI Real Estate Agent – Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────

# ── Twilio (WhatsApp Business) ──────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox or approved number

# ── OpenAI ──────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o                           # or gpt-3.5-turbo

# ── Google (Calendar + Gmail) ────────────────
# Google OAuth2 credentials (Client ID, Client Secret, access/refresh tokens) are
# configured directly in the n8n UI under Settings → Credentials.
# Create a project in Google Cloud Console, enable the Calendar and Gmail APIs,
# and create OAuth 2.0 credentials. Then connect them in n8n – no env vars needed.
#
# The only env var used by the workflow for Google is the target calendar ID:
GOOGLE_CALENDAR_ID=primary   # Use 'primary' or a specific calendar email address

# ── Real Estate Website ──────────────────────
# Base URL of your property listing website
PROPERTY_WEBSITE_BASE_URL=https://www.yourrealestate.com/properties

# ── n8n ─────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
# Webhook path (must match the Webhook node in the workflow)
N8N_WEBHOOK_PATH=whatsapp-real-estate

# ── Agent Settings ───────────────────────────
# Name shown to leads in WhatsApp messages
AGENT_NAME=Priya
REAL_ESTATE_COMPANY_NAME=YourRealty
