# ─────────────────────────────────────────────────────────────────────
# WhatsApp AI Real Estate Agent – Environment Variables
# Copy this file to .env and fill in your values.
# Place .env in the repository root (both backend and n8n read it from there).
# ─────────────────────────────────────────────────────────────────────

# ── Backend Server ───────────────────────────────────────────────────
PORT=3001                          # Express server port
FRONTEND_URL=http://localhost:5173 # React dev server URL (CORS whitelist)

# ── Twilio (WhatsApp Business) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox or approved number

# ── OpenAI ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o                            # gpt-4o | gpt-4o-mini | gpt-4-turbo | gpt-3.5-turbo

# ── Google (Calendar + Gmail) ────────────────────────────────────────
# Create a project in Google Cloud Console, enable the Calendar and Gmail APIs,
# and create OAuth 2.0 credentials (Desktop app type).
# Run the one-time OAuth flow described in README.md to obtain a refresh token.
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
GOOGLE_CALENDAR_ID=primary          # 'primary' or a specific calendar email address
GMAIL_SENDER=you@gmail.com          # Gmail address used to send confirmation emails

# ── Real Estate Website ──────────────────────────────────────────────
PROPERTY_WEBSITE_BASE_URL=https://www.yourrealestate.com/properties

# ── Agent Settings ───────────────────────────────────────────────────
AGENT_NAME=Priya
REAL_ESTATE_COMPANY_NAME=YourRealty

# ── n8n (optional – only needed if also using the n8n workflow) ───────
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_PATH=whatsapp-real-estate
